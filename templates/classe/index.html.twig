{% extends 'base.html.twig' %}
{% block title %}Gestion des classes – EduTest{% endblock %}

{% block stylesheets %}{{ parent() }}
<style>
  .page { padding: 2.5rem 0; min-height: 100vh; }
  .section-card { background:#fff; border-radius:16px; padding:1.75rem; box-shadow:var(--edu-shadow); margin-bottom:1.5rem; border:1px solid var(--edu-border); }
  .level-badge { border-radius:8px; padding:.25rem .7rem; font-size:.78rem; font-weight:700; }
  .class-card { border-radius:14px; border:1px solid var(--edu-border); background:#fff; padding:1.25rem 1.5rem; transition:all .15s; }
  .class-card:hover { transform:translateY(-2px); box-shadow:var(--edu-shadow-md); }
</style>
{% endblock %}

{% block body %}
<div class="page">
<div class="container">

  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
      <h1 class="h2 fw-bold text-primary mb-0"><i class="bi bi-building me-2"></i>Gestion des classes</h1>
      <p class="text-muted small mb-0">{{ classes|length }} classe{{ classes|length > 1 ? 's' : '' }} enregistrée{{ classes|length > 1 ? 's' : '' }}</p>
    </div>
    <a href="{{ path('admin_classes_new') }}" class="btn btn-primary">
      <i class="bi bi-plus-lg me-2"></i>Nouvelle classe
    </a>
  </div>

  {% for message in app.flashes('success') %}
    <div class="alert alert-success border-0 rounded-3">{{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('info') %}
    <div class="alert alert-info border-0 rounded-3">{{ message }}</div>
  {% endfor %}

  {% if classes is empty %}
    <div class="section-card text-center py-5 text-muted">
      <i class="bi bi-building fs-1 mb-3 d-block"></i>
      <h5>Aucune classe créée</h5>
      <p class="small">Créez votre première classe pour organiser les étudiants.</p>
      <a href="{{ path('admin_classes_new') }}" class="btn btn-primary">Créer une classe</a>
    </div>
  {% else %}
    {% set levelColors = {
      'BTS': '#3B82F6', 'BUT': '#8B5CF6', 'Licence': '#22C55E',
      'LicencePro': '#F59E0B', 'Master': '#EF4444', 'Autre': '#6B7280'
    } %}

    <div class="row g-3">
    {% for classe in classes %}
      {% set color = levelColors[classe.level] ?? '#6B7280' %}
      <div class="col-md-6 col-lg-4">
        <div class="class-card">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:42px;height:42px;border-radius:12px;background:{{ color }}20;color:{{ color }};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;flex-shrink:0;">
              {{ classe.year }}
            </div>
            <div>
              <div class="fw-bold">{{ classe.level }} – {{ classe.name }}</div>
              <div class="text-muted small">{{ classe.academicYear }}</div>
            </div>
          </div>
          <div class="d-flex align-items-center justify-content-between">
            <span class="text-muted small">
              <i class="bi bi-people me-1"></i>{{ classe.students|length }} étudiant{{ classe.students|length > 1 ? 's' : '' }}
            </span>
            <div class="d-flex gap-1">
              <a href="{{ path('admin_classes_show', {id: classe.id}) }}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye me-1"></i>Gérer
              </a>
              <a href="{{ path('admin_classes_edit', {id: classe.id}) }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
    </div>
  {% endif %}

</div>
</div>
{% endblock %}
