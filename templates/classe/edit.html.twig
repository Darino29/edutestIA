{% extends 'base.html.twig' %}
{% block title %}Modifier {{ classe.fullLabel }} – EduTest{% endblock %}

{% block stylesheets %}{{ parent() }}
<style>
  .page { padding: 2.5rem 0; min-height: 100vh; }
  .form-card { background:#fff; border-radius:16px; padding:2rem; box-shadow:var(--edu-shadow); max-width:560px; margin:0 auto; border:1px solid var(--edu-border); }
</style>
{% endblock %}

{% block body %}
<div class="page">
<div class="container">
  <div class="d-flex align-items-center mb-4">
    <a href="{{ path('admin_classes_show', {id: classe.id}) }}" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h1 class="h2 fw-bold text-primary mb-0">Modifier la classe</h1>
  </div>

  <div class="form-card">
    <form method="post">
      <div class="mb-3">
        <label class="form-label fw-semibold">Filière / Niveau</label>
        <select class="form-select" name="level" required>
          {% for value, label in levels %}
            <option value="{{ value }}" {% if classe.level == value %}selected{% endif %}>{{ label }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Nom de la classe</label>
        <input type="text" class="form-control" name="name" value="{{ classe.name }}" required>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-6">
          <label class="form-label fw-semibold">Année</label>
          <select class="form-select" name="year">
            {% for y in 1..3 %}
              <option value="{{ y }}" {% if classe.year == y %}selected{% endif %}>{{ y }}{{ y == 1 ? 'ère' : 'ème' }} année</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-6">
          <label class="form-label fw-semibold">Année scolaire</label>
          <input type="text" class="form-control" name="academicYear" value="{{ classe.academicYear }}" pattern="\d{4}-\d{4}" placeholder="2025-2026" required>
        </div>
      </div>
      <div class="d-flex gap-2 justify-content-end">
        <a href="{{ path('admin_classes_show', {id: classe.id}) }}" class="btn btn-outline-secondary">Annuler</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-2"></i>Enregistrer</button>
      </div>
    </form>
  </div>
</div>
</div>
{% endblock %}
