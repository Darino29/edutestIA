{% extends 'base.html.twig' %}

{% block title %}Ma Progression – EduTest{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .progress-page { background: #f8f9fa; padding: 3rem 0; min-height: 100vh; }
        .skill-card {
            border-radius: 12px; padding: 1.25rem; margin-bottom: 0.75rem;
            display: flex; align-items: center; gap: 1rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06); background: #fff;
        }
        .skill-icon { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
        .section-card { background: white; border-radius: 15px; padding: 1.75rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 2rem; }
        .stat-pill { border-radius: 30px; padding: 0.35rem 0.85rem; font-size: 0.78rem; font-weight: 600; white-space: nowrap; }
        .recommendation-content h2 { color: #4c51bf; font-size: 1.3rem; margin-top: 1.4rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.4rem; }
        .recommendation-content h3 { color: #5a67d8; font-size: 1.1rem; margin-top: 1rem; }
        .recommendation-content ul  { padding-left: 1.4rem; margin-bottom: 0.75rem; }
        .recommendation-content li  { margin-bottom: 0.4rem; }
        .recommendation-content strong { color: #2d3748; }
        .bar-wrap { flex: 1; }
        .score-label { font-size: 0.9rem; font-weight: 700; white-space: nowrap; min-width: 48px; text-align: right; }
        .empty-state { text-align: center; padding: 3rem 1rem; color: #6c757d; }
        .exam-chip { display:inline-flex; align-items:center; justify-content:center; border-radius:999px; min-width:28px; height:28px; padding:0 .55rem; font-size:.78rem; font-weight:700; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
{% endblock %}

{% block body %}
<div class="progress-page">
<div class="container">

    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('student_exams') }}" class="btn btn-outline-secondary me-3">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
        <div>
            <h1 class="h2 fw-bold text-primary mb-0"><i class="bi bi-graph-up me-2"></i>Ma Progression</h1>
            <p class="text-muted mb-0 small">Compétences maîtrisées, en cours et à travailler</p>
        </div>
    </div>

    {% set totalTopics = progress.mastered|length + progress.inProgress|length + progress.toWork|length %}

    {% if totalTopics == 0 %}
        <div class="section-card empty-state">
            <i class="bi bi-bar-chart fs-1 text-muted mb-3 d-block"></i>
            <h4>Aucune donnée de progression</h4>
            <p>Passez vos premiers examens pour voir votre tableau de progression ici.</p>
            <a href="{{ path('student_exams') }}" class="btn btn-primary">Voir mes examens</a>
        </div>
    {% else %}

    {# ============ RÉSUMÉ GLOBAL ============ #}
    {% set pctMastered    = totalTopics > 0 ? (progress.mastered|length    / totalTopics * 100)|round : 0 %}
    {% set pctInProgress  = totalTopics > 0 ? (progress.inProgress|length  / totalTopics * 100)|round : 0 %}
    {% set pctToWork      = totalTopics > 0 ? (progress.toWork|length      / totalTopics * 100)|round : 0 %}

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="section-card text-center h-100" style="border-top: 4px solid #22c55e;">
                <div class="display-4 fw-bold text-success">{{ progress.mastered|length }}</div>
                <div class="fs-5 fw-bold text-success mb-1">{{ pctMastered }}%</div>
                <div class="text-muted small">Maîtrisées <span class="fw-semibold">(≥ 75%)</span></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-card text-center h-100" style="border-top: 4px solid #f59e0b;">
                <div class="display-4 fw-bold text-warning">{{ progress.inProgress|length }}</div>
                <div class="fs-5 fw-bold text-warning mb-1">{{ pctInProgress }}%</div>
                <div class="text-muted small">En progression <span class="fw-semibold">(50–74%)</span></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-card text-center h-100" style="border-top: 4px solid #ef4444;">
                <div class="display-4 fw-bold text-danger">{{ progress.toWork|length }}</div>
                <div class="fs-5 fw-bold text-danger mb-1">{{ pctToWork }}%</div>
                <div class="text-muted small">À travailler <span class="fw-semibold">(&lt; 50%)</span></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        {# ======== GRAPHIQUE DOUGHNUT ======== #}
        <div class="col-lg-4">
            <div class="section-card h-100 d-flex flex-column align-items-center justify-content-center">
                <h5 class="fw-bold mb-3 text-center">Répartition globale</h5>
                <canvas id="progressChart" style="max-width: 220px;"></canvas>
            </div>
        </div>

        {# ======== LISTES PAR CATÉGORIE ======== #}
        <div class="col-lg-8">

            {# Maîtrisées #}
            {% if progress.mastered is not empty %}
            <div class="section-card mb-3">
                <h5 class="fw-bold text-success mb-3"><i class="bi bi-check-circle-fill me-2"></i>Compétences maîtrisées</h5>
                {% for item in progress.mastered %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:rgba(34,197,94,.12);color:#16a34a;">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <div class="bar-wrap">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold small">{{ item.topic }}</span>
                            <span style="display:inline-flex;align-items:center;justify-content:center;border-radius:999px;min-width:26px;height:26px;padding:0 6px;font-size:.78rem;font-weight:700;background:#bbf7d0;color:#14532d;">{{ item.examsCount }}</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: {{ item.score }}%"></div>
                        </div>
                    </div>
                    <span class="score-label text-success">{{ item.score }}%</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            {# En progression #}
            {% if progress.inProgress is not empty %}
            <div class="section-card mb-3">
                <h5 class="fw-bold text-warning mb-3"><i class="bi bi-arrow-up-circle-fill me-2"></i>En progression</h5>
                {% for item in progress.inProgress %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:rgba(245,158,11,.12);color:#d97706;">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <div class="bar-wrap">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold small">{{ item.topic }}</span>
                            <span style="display:inline-flex;align-items:center;justify-content:center;border-radius:999px;min-width:26px;height:26px;padding:0 6px;font-size:.78rem;font-weight:700;background:#fde68a;color:#78350f;">{{ item.examsCount }}</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-warning" style="width: {{ item.score }}%"></div>
                        </div>
                    </div>
                    <span class="score-label text-warning">{{ item.score }}%</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            {# À travailler #}
            {% if progress.toWork is not empty %}
            <div class="section-card mb-3">
                <h5 class="fw-bold text-danger mb-3"><i class="bi bi-exclamation-circle-fill me-2"></i>À travailler en priorité</h5>
                {% for item in progress.toWork %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:rgba(239,68,68,.12);color:#dc2626;">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <div class="bar-wrap">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold small">{{ item.topic }}</span>
                            <div class="d-flex gap-1">
                                <span style="display:inline-flex;align-items:center;justify-content:center;border-radius:999px;min-width:26px;height:26px;padding:0 6px;font-size:.78rem;font-weight:700;background:#fecaca;color:#7f1d1d;">{{ item.examsCount }}</span>
                                <a href="{{ path('app_ai_revision') }}" class="stat-pill text-decoration-none" style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;">
                                    <i class="bi bi-robot me-1"></i>Réviser
                                </a>
                            </div>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-danger" style="width: {{ item.score }}%"></div>
                        </div>
                    </div>
                    <span class="score-label text-danger">{{ item.score }}%</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

        </div>
    </div>

    {# ======== RECOMMANDATIONS IA (chargées en AJAX) ======== #}
    {% if totalTopics > 0 %}
    <div class="section-card mt-2" id="recommendations-card">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                <span class="fs-2">🤖</span>
                <div>
                    <h5 class="fw-bold mb-0">Recommandations personnalisées</h5>
                    <small class="text-muted">Générées par IA selon votre profil de progression</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-warning d-none" id="reco-play-btn">
                    <i class="fas fa-volume-up me-1"></i>Écouter
                </button>
                <button class="btn btn-sm btn-outline-danger d-none" id="reco-stop-btn">
                    <i class="fas fa-stop me-1"></i>Stop
                </button>
            </div>
        </div>
        <hr>
        <div id="recommendations-loading" class="text-center py-3">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2 small">Génération des recommandations IA…</p>
        </div>
        <div id="recommendations-output" class="recommendation-content" style="display:none;"></div>
    </div>
    {% endif %}

    {% endif %}{# end totalTopics > 0 #}

</div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        {% set totalTopics = progress.mastered|length + progress.inProgress|length + progress.toWork|length %}
        {% if totalTopics > 0 %}
        // Doughnut chart
        new Chart(document.getElementById('progressChart'), {
            type: 'doughnut',
            data: {
                labels: ['Maîtrisées', 'En progression', 'À travailler'],
                datasets: [{
                    data: [{{ progress.mastered|length }}, {{ progress.inProgress|length }}, {{ progress.toWork|length }}],
                    backgroundColor: ['#22c55e', '#f59e0b', '#ef4444'],
                    borderWidth: 2,
                    borderColor: '#fff',
                }]
            },
            options: {
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 12 } } },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                const pct = total > 0 ? Math.round(ctx.parsed / total * 100) : 0;
                                return '  ' + ctx.label + ' : ' + ctx.parsed + ' (' + pct + '%)';
                            }
                        }
                    }
                }
            }
        });
        {% endif %}

        // Chargement AJAX des recommandations IA
        const recoCard    = document.getElementById('recommendations-card');
        const recoLoading = document.getElementById('recommendations-loading');
        const recoOutput  = document.getElementById('recommendations-output');
        const recoPlay    = document.getElementById('reco-play-btn');
        const recoStop    = document.getElementById('reco-stop-btn');

        if (recoCard) {
            fetch('{{ path('student_progress_recommendations') }}')
                .then(r => r.json())
                .then(data => {
                    if (!data.text || data.text.startsWith('ERREUR_')) {
                        recoCard.style.display = 'none';
                        return;
                    }
                    const recoText = data.text;
                    recoOutput.innerHTML = marked.parse(recoText);
                    recoLoading.style.display = 'none';
                    recoOutput.style.display   = '';
                    recoPlay.classList.remove('d-none');

                    recoPlay.addEventListener('click', function () {
                        if (speechSynthesis.speaking) return;
                        const plain = recoText.replace(/[#*_`~>\-]/g, '').trim();
                        const utt = new SpeechSynthesisUtterance(plain);
                        utt.lang = 'fr-FR'; utt.rate = 0.95;
                        utt.onend  = () => recoStop.classList.add('d-none');
                        utt.onerror = () => recoStop.classList.add('d-none');
                        recoStop.classList.remove('d-none');
                        speechSynthesis.speak(utt);
                    });
                    recoStop.addEventListener('click', function () {
                        speechSynthesis.cancel();
                        this.classList.add('d-none');
                    });
                })
                .catch(() => { recoCard.style.display = 'none'; });
        }
    });
    </script>
{% endblock %}
