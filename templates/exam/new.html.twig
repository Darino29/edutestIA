{% extends 'base.html.twig' %}

{% block title %}Nouvel examen | EduTest{% endblock %}

{% block body %}
<div class="container-xl py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i> Nouvel examen
                    </h4>
                    <a href="{{ path('app_exam_index') }}" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form, {
                        attr: {
                            class: 'needs-validation',
                            novalidate: 'novalidate'
                        }
                    }) }}

                    {# Titre #}
                    <div class="mb-3">
                        {{ form_label(form.title, 'Titre de l’examen', {
                            label_attr: { class: 'form-label fw-semibold' }
                        }) }}
                        {{ form_widget(form.title, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Ex : Mathématiques - Chapitre 3'
                            }
                        }) }}
                        {{ form_errors(form.title) }}
                    </div>

                    {# Description #}
                    <div class="mb-3">
                        {{ form_label(form.description, 'Description', {
                            label_attr: { class: 'form-label fw-semibold' }
                        }) }}
                        {{ form_widget(form.description, {
                            attr: {
                                class: 'form-control',
                                rows: 3,
                                placeholder: 'Décrivez rapidement le contenu de l’examen (facultatif)...'
                            }
                        }) }}
                        {{ form_errors(form.description) }}
                    </div>

                    {# Durée + dates #}
                    <div class="row g-3">
                        <div class="col-md-4">
                            {{ form_label(form.durationMinutes, 'Durée (minutes)', {
                                label_attr: { class: 'form-label fw-semibold' }
                            }) }}
                            {{ form_widget(form.durationMinutes, {
                                attr: {
                                    class: 'form-control',
                                    min: 1
                                }
                            }) }}
                            {{ form_errors(form.durationMinutes) }}
                        </div>

                        <div class="col-md-4">
                            {{ form_label(form.startAt, 'Date de début', {
                                label_attr: { class: 'form-label fw-semibold' }
                            }) }}
                            {{ form_widget(form.startAt, {
                                attr: { class: 'form-control' }
                            }) }}
                            {{ form_errors(form.startAt) }}
                        </div>

                        <div class="col-md-4">
                            {{ form_label(form.endAt, 'Date de fin', {
                                label_attr: { class: 'form-label fw-semibold' }
                            }) }}
                            {{ form_widget(form.endAt, {
                                attr: { class: 'form-control' }
                            }) }}
                            {{ form_errors(form.endAt) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="{{ path('app_exam_index') }}" class="btn btn-outline-secondary">
                            Annuler
                        </a>
                        <button type="button" class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#difficultyModal">
                            <i class="bi bi-magic me-1"></i> Générer
                        </button>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-circle me-1"></i> Créer l’examen
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <p class="text-center text-muted small mt-3">
                💡 Les questions seront ajoutées après la création de l’examen.
            </p>
        </div>
    </div>
</div>

<!-- Modal de sélection de difficulté -->
<div class="modal fade" id="difficultyModal" tabindex="-1" aria-labelledby="difficultyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered"> {# Ajout de modal-dialog-centered ici #}
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="difficultyModalLabel">Choisir la difficulté</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body">
        <select id="difficultySelect" class="form-select">
          <option value="Facile">Facile</option>
          <option value="Moyen" selected>Moyen</option>
          <option value="Difficile">Difficile</option>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="confirmDifficultyBtn">Générer</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.getElementById('confirmDifficultyBtn').addEventListener('click', function() {
    const difficulty = document.getElementById('difficultySelect').value;
    // Ajoute un champ caché au formulaire pour la difficulté
    let input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'difficulty';
    input.value = difficulty;
    document.querySelector('form').appendChild(input);

    // Change l'action du formulaire pour pointer sur le endpoint IA
    document.querySelector('form').setAttribute('action', "{{ path('app_ai_quiz') }}");
    document.querySelector('form').submit();
});
</script>
{% endblock %}