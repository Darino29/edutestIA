{# templates/home/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}EduTest – Plateforme d'examens en ligne{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  .hero-section {
    background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 55%, #6366F1 100%);
    padding: 6rem 0 5rem;
    text-align: center;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,.15);
    color: rgba(255,255,255,.9);
    border: 1px solid rgba(255,255,255,.25);
    border-radius: 999px;
    padding: .3rem 1rem;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(6px);
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 1.2rem;
  }
  .hero-title span { color: #FCD34D; }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,.78);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  .hero-cta { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .hero-proof { font-size: .82rem; color: rgba(255,255,255,.5); }
  .hero-proof strong { color: #fff; }

  .features-section { background: var(--edu-bg); padding: 4.5rem 0; }
  .features-eyebrow {
    font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--edu-primary); margin-bottom: .5rem;
  }
  .features-title { font-size: 1.7rem; font-weight: 800; margin-bottom: .5rem; }
  .features-sub { color: var(--edu-muted); margin-bottom: 3rem; }

  .feat-card {
    background: #fff;
    border: 1px solid var(--edu-border);
    border-radius: 18px;
    padding: 2rem 1.75rem;
    height: 100%;
    transition: transform .18s, box-shadow .18s;
  }
  .feat-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(15,23,42,.09); }
  .feat-icon {
    width: 50px; height: 50px; border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; margin-bottom: 1.1rem;
  }
  .feat-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: .4rem; }
  .feat-card p { font-size: .88rem; color: var(--edu-muted); margin: 0; line-height: 1.55; }

  .stats-section { padding: 3rem 0; border-top: 1px solid var(--edu-border); }
  .stat-item { text-align: center; }
  .stat-value { font-size: 2rem; font-weight: 900; color: var(--edu-primary); line-height: 1; }
  .stat-label { font-size: .82rem; color: var(--edu-muted); margin-top: .3rem; }
</style>
{% endblock %}

{% block body %}

{# ── HERO ── #}
<section class="hero-section">
  <div class="container">
    <div class="hero-badge"><i class="bi bi-mortarboard me-1"></i>Plateforme d'évaluation en ligne</div>
    <h1 class="hero-title">
      Vos examens,<br>organisés avec <span>EduTest</span>
    </h1>
    <p class="hero-sub">
      Créez, affectez et corrigez vos examens en ligne.<br>
      Les étudiants passent, les résultats arrivent.
    </p>
    <div class="hero-cta">
      <a href="{{ path('app_login') }}" class="btn btn-light btn-lg px-5 fw-semibold">
        <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
      </a>
      <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg px-5 fw-semibold">
        <i class="bi bi-person-plus me-2"></i>Créer un compte
      </a>
    </div>
    <p class="hero-proof">
      Déjà utilisée par <strong>+200</strong> étudiants et <strong>+10</strong> enseignants
    </p>
  </div>
</section>

{# ── FEATURES ── #}
<section class="features-section">
  <div class="container">
    <div class="text-center">
      <div class="features-eyebrow">Fonctionnalités</div>
      <h2 class="features-title">Tout ce qu'il vous faut</h2>
      <p class="features-sub">Simple, rapide, adapté aux formations BTS, Licence et Master.</p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="feat-card">
          <div class="feat-icon" style="background:rgba(59,130,246,.1);color:#3B82F6;">
            <i class="bi bi-journal-plus"></i>
          </div>
          <h3>Création d'examens</h3>
          <p>QCM ou texte libre, durée, période — créez et affectez en quelques clics.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feat-card">
          <div class="feat-icon" style="background:rgba(34,197,94,.1);color:#16A34A;">
            <i class="bi bi-laptop"></i>
          </div>
          <h3>Passation sécurisée</h3>
          <p>Minuterie intégrée, tentative unique, détection anti-triche et sauvegarde automatique.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feat-card">
          <div class="feat-icon" style="background:rgba(245,158,11,.1);color:#D97706;">
            <i class="bi bi-bar-chart-line"></i>
          </div>
          <h3>Résultats & IA</h3>
          <p>Correction auto, stats par examen, export CSV/PDF et recommandations personnalisées par IA.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# ── STATS ── #}
<section class="stats-section">
  <div class="container">
    <div class="row g-4 justify-content-center">
      <div class="col-4 col-md-2">
        <div class="stat-item">
          <div class="stat-value">+200</div>
          <div class="stat-label">Étudiants</div>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="stat-item">
          <div class="stat-value">+10</div>
          <div class="stat-label">Enseignants</div>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="stat-item">
          <div class="stat-value">+50</div>
          <div class="stat-label">Examens</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% endblock %}

{% block javascripts %}{{ parent() }}{% endblock %}
