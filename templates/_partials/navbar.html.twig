{# templates/_partials/navbar.html.twig #}

<nav class="navbar navbar-expand-lg fixed-top edutest-navbar">
  <div class="container">

    {# LOGO #}
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('home') }}">
      <div class="navbar-logo-icon">
        <i class="bi bi-mortarboard-fill"></i>
      </div>
      <span class="navbar-brand-text">EduTest</span>
    </a>

    {# BURGER MOBILE #}
    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarNav" aria-controls="navbarNav"
            aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

        {% if app.user %}

          {# === ADMIN === #}
          {% if 'ROLE_ADMIN' in app.user.roles %}
            {% set isAdminRoute = app.request.get('_route') starts with 'admin_' %}
            {% if isAdminRoute %}
              <li class="nav-item"><a class="nav-link nav-link-modern" href="#users-section">Utilisateurs</a></li>
              <li class="nav-item"><a class="nav-link nav-link-modern" href="#exams-section">Examens</a></li>
            {% else %}
              <li class="nav-item">
                <a href="{{ path('admin_dashboard') }}" class="btn btn-navbar-ghost">
                  <i class="bi bi-gear-fill me-1"></i> Admin
                </a>
              </li>
            {% endif %}
            <li class="nav-item">
              <a href="{{ path('admin_classes_index') }}" class="btn btn-navbar-ghost">
                <i class="bi bi-building me-1"></i> Classes
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('admin_ai_insights') }}" class="btn btn-navbar-ai">
                <i class="bi bi-bar-chart-fill me-1"></i> Rapport IA
              </a>
            </li>
          {% endif %}

          {# === ENSEIGNANT === #}
          {% if 'ROLE_TEACHER' in app.user.roles %}
            <li class="nav-item">
              <a href="{{ path('teacher_dashboard') }}" class="btn btn-navbar-primary">
                <i class="bi bi-easel-fill me-1"></i> Tableau de bord
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('app_exam_index') }}" class="btn btn-navbar-ghost">
                <i class="bi bi-journal-text me-1"></i> Examens
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('teacher_students_progress') }}" class="btn btn-navbar-ghost">
                <i class="bi bi-graph-up me-1"></i> Progression
              </a>
            </li>
          {% endif %}

          {# === ÉTUDIANT : dropdown Outils IA === #}
          {% if 'ROLE_STUDENT' in app.user.roles %}
            <li class="nav-item dropdown">
              <button class="btn btn-navbar-ai dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-robot me-1"></i> Outils IA
              </button>
              <ul class="dropdown-menu dropdown-menu-modern shadow-lg border-0">
                <li>
                  <a class="dropdown-item dropdown-item-modern" href="{{ path('app_ai_revision') }}">
                    <i class="bi bi-file-earmark-text text-primary me-2"></i>
                    <div>
                      <div class="fw-semibold">Révision</div>
                      <small class="text-muted">Fiches de révision IA</small>
                    </div>
                  </a>
                </li>
                <li>
                  <a class="dropdown-item dropdown-item-modern" href="{{ path('app_ai_explain') }}">
                    <i class="bi bi-book-half text-indigo me-2"></i>
                    <div>
                      <div class="fw-semibold">Explications</div>
                      <small class="text-muted">Cours expliqués par niveau</small>
                    </div>
                  </a>
                </li>
                <li>
                  <a class="dropdown-item dropdown-item-modern" href="{{ path('student_progress') }}">
                    <i class="bi bi-graph-up text-success me-2"></i>
                    <div>
                      <div class="fw-semibold">Ma progression</div>
                      <small class="text-muted">Compétences & recommandations</small>
                    </div>
                  </a>
                </li>
              </ul>
            </li>
            <li class="nav-item">
              <a href="{{ path('student_exams') }}" class="btn btn-navbar-primary">
                <i class="bi bi-mortarboard-fill me-1"></i> Mes examens
              </a>
            </li>
          {% endif %}

          {# AVATAR DROPDOWN #}
          <li class="nav-item dropdown ms-lg-2">
            <button class="btn p-0 border-0 bg-transparent dropdown-toggle no-caret" data-bs-toggle="dropdown" aria-expanded="false">
              <div class="avatar-circle">
                {% if app.user.profilePicture %}
                  <img src="{{ asset('uploads/avatars/' ~ app.user.profilePicture) }}" alt="avatar">
                {% else %}
                  {{ (app.user.fullName ?? app.user.userIdentifier)|first|upper }}
                {% endif %}
              </div>
            </button>
            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-modern shadow-lg border-0" style="min-width:220px;">
              <li class="px-3 py-2 border-bottom mb-1">
                <div class="fw-semibold text-dark small">{{ app.user.fullName ?? app.user.userIdentifier }}</div>
                <div class="text-muted" style="font-size:0.75rem;">{{ app.user.email }}</div>
              </li>
              <li>
                <a class="dropdown-item dropdown-item-modern" href="{{ path('app_profile') }}">
                  <i class="bi bi-person-circle me-2 text-primary"></i> Mon profil
                </a>
              </li>
              <li><hr class="dropdown-divider my-1"></li>
              <li>
                <a class="dropdown-item dropdown-item-modern text-danger" href="{{ path('app_logout') }}">
                  <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                </a>
              </li>
            </ul>
          </li>

        {% else %}
          <li class="nav-item">
            <a class="nav-link nav-link-modern" href="{{ path('app_login') }}">Se connecter</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-navbar-primary" href="{{ path('app_register') }}">
              <i class="bi bi-person-plus me-1"></i> Créer un compte
            </a>
          </li>
        {% endif %}

      </ul>
    </div>
  </div>
</nav>
