<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% block title %}EduTest{% endblock %}</title>

    {# Bootstrap + Icônes #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">

    {% block stylesheets %}
    <style>
      /* ===== DESIGN SYSTEM ===== */
      :root {
        --edu-primary:    #3B82F6;
        --edu-primary-dk: #2563EB;
        --edu-indigo:     #6366F1;
        --edu-gold:       #F59E0B;
        --edu-success:    #22C55E;
        --edu-danger:     #EF4444;
        --edu-bg:         #F1F5F9;
        --edu-card:       #FFFFFF;
        --edu-text:       #1E293B;
        --edu-muted:      #64748B;
        --edu-border:     #E2E8F0;
        --edu-radius:     14px;
        --edu-shadow:     0 4px 24px rgba(15,23,42,.08);
        --edu-shadow-md:  0 8px 32px rgba(15,23,42,.12);
      }

      html { height: 100%; scroll-behavior: smooth; }

      body {
        min-height: 100%;
        display: flex;
        flex-direction: column;
        padding-top: 72px;
        background-color: var(--edu-bg);
        color: var(--edu-text);
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
      }

      main { flex: 1 0 auto; }

      /* ===== NAVBAR ===== */
      .edutest-navbar {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--edu-border);
        box-shadow: 0 1px 16px rgba(15,23,42,.06);
        padding: 0.55rem 0;
        transition: box-shadow 0.2s;
      }

      .navbar-logo-icon {
        width: 34px; height: 34px;
        background: linear-gradient(135deg, var(--edu-primary), var(--edu-indigo));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.1rem;
        box-shadow: 0 2px 8px rgba(59,130,246,.35);
      }

      .navbar-brand-text {
        font-weight: 800; font-size: 1.2rem;
        background: linear-gradient(135deg, var(--edu-primary), var(--edu-indigo));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }

      .nav-link-modern {
        color: var(--edu-muted) !important;
        font-weight: 500; font-size: 0.9rem; padding: 0.45rem 0.75rem !important;
        border-radius: 8px; transition: all 0.15s;
      }
      .nav-link-modern:hover { color: var(--edu-primary) !important; background: #EFF6FF; }

      .btn-navbar-primary {
        background: linear-gradient(135deg, var(--edu-primary), var(--edu-primary-dk));
        color: #fff; border: none; border-radius: 9px;
        padding: 0.42rem 1rem; font-size: 0.875rem; font-weight: 600;
        box-shadow: 0 2px 8px rgba(59,130,246,.3);
        transition: all 0.15s;
      }
      .btn-navbar-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(59,130,246,.4); color:#fff; }

      .btn-navbar-ghost {
        color: var(--edu-text); background: transparent;
        border: 1.5px solid var(--edu-border); border-radius: 9px;
        padding: 0.42rem 0.9rem; font-size: 0.875rem; font-weight: 500;
        transition: all 0.15s;
      }
      .btn-navbar-ghost:hover { border-color: var(--edu-primary); color: var(--edu-primary); background: #EFF6FF; }

      .btn-navbar-ai {
        background: linear-gradient(135deg, #7C3AED, var(--edu-indigo));
        color: #fff; border: none; border-radius: 9px;
        padding: 0.42rem 1rem; font-size: 0.875rem; font-weight: 600;
        box-shadow: 0 2px 8px rgba(99,102,241,.3);
        transition: all 0.15s;
      }
      .btn-navbar-ai:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(99,102,241,.4); color:#fff; }
      .btn-navbar-ai.dropdown-toggle::after { margin-left: 6px; }

      /* Avatar */
      .avatar-circle {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, var(--edu-primary), var(--edu-indigo));
        color: #fff; font-weight: 700; font-size: 0.9rem;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: box-shadow 0.15s;
        overflow: hidden; border: 2px solid #fff;
        box-shadow: 0 2px 8px rgba(59,130,246,.25);
      }
      .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
      .avatar-circle:hover { box-shadow: 0 4px 14px rgba(59,130,246,.4); }
      .no-caret::after { display: none !important; }

      /* Dropdowns */
      .dropdown-menu-modern { border-radius: 14px; padding: 0.5rem; min-width: 200px; }
      .dropdown-item-modern {
        border-radius: 9px; padding: 0.55rem 0.75rem;
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.875rem; transition: background 0.12s; color: var(--edu-text);
      }
      .dropdown-item-modern:hover { background: #F1F5F9; }
      .dropdown-item-modern.text-danger:hover { background: #FEF2F2; }
      .text-indigo { color: var(--edu-indigo); }

      /* ===== CARDS ===== */
      .card, .section-card {
        border-radius: var(--edu-radius) !important;
        border: 1px solid var(--edu-border) !important;
        box-shadow: var(--edu-shadow);
        background: var(--edu-card);
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .card:hover { transform: translateY(-2px); box-shadow: var(--edu-shadow-md); }

      /* ===== BUTTONS (global) ===== */
      .btn { border-radius: 9px !important; font-weight: 500; transition: all 0.15s; }
      .btn-primary { background: linear-gradient(135deg, var(--edu-primary), var(--edu-primary-dk)) !important; border: none !important; box-shadow: 0 2px 8px rgba(59,130,246,.25); }
      .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(59,130,246,.35) !important; }
      .btn-gold { background: linear-gradient(135deg, #FBBF24, var(--edu-gold)); border: none; color: #1E293B; font-weight: 600; }
      .btn-gold:hover { transform: translateY(-1px); color: #1E293B; }

      /* ===== FORMS ===== */
      .form-control, .form-select {
        border-radius: 10px !important;
        border: 1.5px solid var(--edu-border) !important;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .form-control:focus, .form-select:focus {
        border-color: var(--edu-primary) !important;
        box-shadow: 0 0 0 3px rgba(59,130,246,.15) !important;
      }

      /* ===== BADGES ===== */
      .badge { border-radius: 6px !important; font-weight: 600; }

      /* ===== MISC ===== */
      .admin-layout { min-height: calc(100vh - 72px); padding: 1.5rem 0; }
      .landing-hero { margin-top: 10px; }

      .footer { font-size: 0.85rem; background: #fff; border-top: 1px solid var(--edu-border); }
      .footer span, .footer a { color: var(--edu-muted); }
      .footer a:hover { color: var(--edu-primary); text-decoration: none; }

      .auth-wrapper { min-height: calc(100vh - 72px); padding: 2rem 1rem; }
      .auth-card { max-width: 420px; width: 100%; border-radius: 1rem; background: #fff; }
      .auth-icon {
        width: 46px; height: 46px; border-radius: 999px;
        display: inline-flex; align-items: center; justify-content: center;
        background: #EFF6FF; color: var(--edu-primary); font-size: 1.4rem;
      }

      /* ===== CHATBOT ===== */
      #chatbot-fab {
        position: fixed; bottom: 28px; right: 28px; z-index: 1050;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, var(--edu-indigo), #7C3AED);
        border: none; color: #fff; font-size: 1.4rem;
        box-shadow: 0 4px 20px rgba(99,102,241,.45);
        cursor: pointer; transition: all 0.2s;
        display: flex; align-items: center; justify-content: center;
      }
      #chatbot-fab:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(99,102,241,.55); }

      #chatbot-panel {
        position: fixed; bottom: 96px; right: 28px; z-index: 1049;
        width: 360px; height: 520px;
        background: #fff; border-radius: 20px;
        box-shadow: 0 12px 48px rgba(15,23,42,.18);
        display: flex; flex-direction: column;
        overflow: hidden; border: 1px solid var(--edu-border);
        transform: scale(0.92) translateY(16px);
        opacity: 0; pointer-events: none;
        transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
      }
      #chatbot-panel.open { transform: scale(1) translateY(0); opacity: 1; pointer-events: all; }

      .chatbot-header {
        background: linear-gradient(135deg, var(--edu-indigo), #7C3AED);
        color: #fff; padding: 1rem 1.2rem;
        display: flex; align-items: center; justify-content: space-between;
      }
      .chatbot-header h6 { margin: 0; font-weight: 700; font-size: 0.95rem; }
      .chatbot-header small { opacity: 0.8; font-size: 0.75rem; }
      .chat-close-btn { background: rgba(255,255,255,.2); border: none; color:#fff; border-radius:8px; padding:4px 8px; cursor:pointer; transition:background 0.15s; }
      .chat-close-btn:hover { background: rgba(255,255,255,.35); }

      #chat-messages {
        flex: 1; overflow-y: auto; padding: 1rem;
        display: flex; flex-direction: column; gap: 0.6rem;
        scroll-behavior: smooth;
      }
      .chat-msg { max-width: 82%; padding: 0.6rem 0.9rem; border-radius: 14px; font-size: 0.84rem; line-height: 1.5; word-break: break-word; }
      .chat-msg.user { align-self: flex-end; background: linear-gradient(135deg, var(--edu-primary), var(--edu-primary-dk)); color:#fff; border-bottom-right-radius: 4px; }
      .chat-msg.bot  { align-self: flex-start; background: #F1F5F9; color: var(--edu-text); border-bottom-left-radius: 4px; }
      .chat-msg.bot.typing { color: var(--edu-muted); font-style: italic; }

      .chatbot-limit-bar { padding: 0.35rem 1rem; background: #F8FAFC; border-top: 1px solid var(--edu-border); text-align: right; }
      .chatbot-limit-bar small { color: var(--edu-muted); font-size: 0.72rem; }

      #chat-form { padding: 0.75rem; border-top: 1px solid var(--edu-border); display: flex; gap: 0.5rem; }
      #chat-input { flex: 1; border-radius: 10px !important; border: 1.5px solid var(--edu-border) !important; font-size: 0.85rem; padding: 0.5rem 0.75rem; outline: none; resize: none; height: 40px; }
      #chat-input:focus { border-color: var(--edu-indigo) !important; box-shadow: 0 0 0 3px rgba(99,102,241,.15); }
      #chat-send { background: linear-gradient(135deg, var(--edu-indigo), #7C3AED); color:#fff; border:none; border-radius:10px; padding:0 14px; cursor:pointer; transition:all 0.15s; font-size:1rem; }
      #chat-send:hover { transform: scale(1.05); }
      #chat-send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    </style>
    {% endblock %}
  </head>

  <body class="d-flex flex-column min-vh-100">
    {% include '_partials/navbar.html.twig' %}
    {# ========================== # CONTENU PRINCIPAL # ========================== #}
    <main class="flex-grow-1 container-fluid p-0">{% block body %}{% endblock %}</main>

    {# ========================== # FOOTER GLOBAL (toujours affiché) # ========================== #} 
    {% include '_partials/footer.html.twig' %} 

    {# ========================== # SCRIPTS JS # ========================== #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    {% if app.user %}
    {# ===== CHATBOT FLOTTANT ===== #}
    <button id="chatbot-fab" title="EduBot – Assistant IA">
      <i class="bi bi-chat-dots-fill"></i>
    </button>

    <div id="chatbot-panel">
      <div class="chatbot-header">
        <div>
          <h6><i class="bi bi-robot me-2"></i>EduBot</h6>
          <small>Assistant pédagogique IA</small>
        </div>
        <button class="chat-close-btn" id="chat-close"><i class="bi bi-x-lg"></i></button>
      </div>

      <div id="chat-messages">
        <div class="chat-msg bot">
          Bonjour {{ app.user.fullName ?? 'toi' }} 👋 Je suis EduBot, ton assistant pédagogique. Comment puis-je t'aider ?
        </div>
      </div>

      <div class="chatbot-limit-bar">
        <small id="chat-counter">10 messages restants aujourd'hui</small>
      </div>

      <form id="chat-form" autocomplete="off">
        <input type="text" id="chat-input" placeholder="Pose ta question..." maxlength="500">
        <button type="submit" id="chat-send"><i class="bi bi-send-fill"></i></button>
      </form>
    </div>

    <script>
    (function () {
      const LIMIT      = 10;
      const STORAGE_KEY = 'edubot_usage';
      const fab        = document.getElementById('chatbot-fab');
      const panel      = document.getElementById('chatbot-panel');
      const closeBtn   = document.getElementById('chat-close');
      const form       = document.getElementById('chat-form');
      const input      = document.getElementById('chat-input');
      const sendBtn    = document.getElementById('chat-send');
      const messagesEl = document.getElementById('chat-messages');
      const counterEl  = document.getElementById('chat-counter');

      let conversation = [];
      let isOpen = false;

      // --- Gestion limite journalière ---
      function getUsage() {
        try {
          const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
          const today = new Date().toDateString();
          if (data.date !== today) return { date: today, count: 0 };
          return data;
        } catch { return { date: new Date().toDateString(), count: 0 }; }
      }

      function saveUsage(usage) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(usage));
      }

      function updateCounter() {
        const usage    = getUsage();
        const remaining = Math.max(0, LIMIT - usage.count);
        counterEl.textContent = remaining + ' message' + (remaining > 1 ? 's' : '') + ' restant' + (remaining > 1 ? 's' : '') + ' aujourd\'hui';
        if (remaining === 0) {
          sendBtn.disabled = true;
          input.disabled   = true;
          input.placeholder = 'Limite atteinte. Revenez demain.';
        }
      }

      // --- UI ---
      fab.addEventListener('click', () => {
        isOpen = !isOpen;
        panel.classList.toggle('open', isOpen);
        if (isOpen) { updateCounter(); input.focus(); }
      });

      closeBtn.addEventListener('click', () => { isOpen = false; panel.classList.remove('open'); });

      function appendMsg(role, text) {
        const div = document.createElement('div');
        div.className = 'chat-msg ' + role;
        div.textContent = text;
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return div;
      }

      // --- Envoi ---
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;

        const usage = getUsage();
        if (usage.count >= LIMIT) { updateCounter(); return; }

        input.value = '';
        sendBtn.disabled = true;
        appendMsg('user', text);

        conversation.push({ role: 'user', content: text });

        const typing = appendMsg('bot typing', '…');

        try {
          const res = await fetch('/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: conversation }),
          });
          const data = await res.json();
          const reply = data.reply || 'Désolé, une erreur est survenue.';
          typing.className = 'chat-msg bot';
          typing.textContent = reply;
          conversation.push({ role: 'assistant', content: reply });
        } catch {
          typing.className = 'chat-msg bot';
          typing.textContent = 'Erreur de connexion. Réessayez.';
        }

        usage.count++;
        saveUsage(usage);
        updateCounter();
        sendBtn.disabled = false;
        input.focus();
        messagesEl.scrollTop = messagesEl.scrollHeight;
      });

      updateCounter();
    })();
    </script>
    {% endif %}

    {% block javascripts %}{% endblock %}
  </body>
</html>