{% extends 'base.html.twig' %}

{% block title %}Révision Intelligente - EduTest{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .revision-page {
            background-color: #f8f9fa;
            padding: 3rem 0;
            min-height: 100vh;
        }
        .search-area {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin-bottom: 2rem;
        }
        .btn-gold {
            background-color: #FFD700;
            border-color: #FFC107;
            color: #212529;
        }
        .btn-gold:hover, .btn-gold:focus {
            background-color: #FFC107;
            border-color: #FFD700;
            color: #212529;
        }
        .result-area {
            background: white;
            border-radius: 15px;
            padding: 3rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            opacity: 0;
            animation: fadeIn 0.5s ease forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .loading-spinner {
            display: none;
        }
        .markdown-content h1 { color: #5a67d8; font-size: 2rem; margin-top: 1.5rem; }
        .markdown-content h2 { color: #4c51bf; font-size: 1.5rem; margin-top: 1.2rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; }
        .markdown-content ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
        .markdown-content li { margin-bottom: 0.5rem; }
        .markdown-content strong { color: #2d3748; }
    </style>
    {# Use marked.js for markdown rendering #}
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
{% endblock %}

{% block body %}
<div class="revision-page">
    <div class="container">
        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('student_exams') }}" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i> Retour</a>
            <h1 class="h2 fw-bold text-primary mb-0">Assistant de Révision</h1>
        </div>

        <!-- Formulaire -->
        <div class="search-area">
            <form method="post" onsubmit="document.getElementById('spinner').style.display = 'block';">
                <div class="mb-3">
                    <label for="topic" class="form-label h5">Sur quel sujet souhaitez-vous réviser ?</label>
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" id="topic" name="topic" placeholder="Ex: La Révolution Française, Algèbre Linéaire, Le cycle de l'eau..." required value="{{ topic }}">
                        <button class="btn btn-primary px-4" type="submit">
                            <i class="fas fa-magic me-2"></i>Générer
                        </button>
                    </div>
                    <div class="form-text mt-2">Notre IA analysera le sujet et créera une fiche complète.</div>
                </div>
            </form>
            
            <!-- Loader -->
            <div id="spinner" class="text-center py-4 loading-spinner">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Chargement...</span>
                </div>
                <p class="mt-3 text-muted">L'IA rédige votre fiche de révision, veuillez patienter...</p>
            </div>
        </div>

        <!-- Résultat -->
        {% if result %}
        <div class="result-area">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h4 text-muted">Fiche de révision : <span class="text-dark">{{ topic }}</span></h3>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-2" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>Imprimer
                    </button>
                    <button class="btn btn-sm btn-outline-success me-2" id="save-revision-btn">
                        <i class="fas fa-bookmark me-2"></i>Sauvegarder
                    </button>
                    <button class="btn btn-sm btn-gold" id="play-audio-btn">
                        <i class="fas fa-volume-up me-2"></i>Écouter
                    </button>
                    <button class="btn btn-sm btn-outline-danger ms-2 d-none" id="stop-audio-btn">
                        <i class="fas fa-stop me-2"></i>Stop
                    </button>
                </div>
            </div>
            <hr>
            <div id="markdown-output" class="markdown-content">
                <!-- Le contenu brut sera converti par JS -->
                {{ result }}
            </div>
        </div>
        {% endif %}

        {% if savedRevisions is defined and savedRevisions|length > 0 %}
        <div class="mt-4" id="saved-section">
            <h4 class="h5 fw-bold text-secondary mb-3"><i class="fas fa-bookmark me-2"></i>Fiches sauvegardées</h4>
            <div class="list-group">
                {% for rev in savedRevisions %}
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                     id="saved-item-{{ rev.id }}"
                     data-topic="{{ rev.topic|e('html_attr') }}"
                     data-content="{{ rev.content|e('html_attr') }}">
                    <div>
                        <strong>{{ rev.topic }}</strong>
                        <small class="text-muted ms-2">{{ rev.createdAt|date('d/m/Y H:i') }}</small>
                    </div>
                    <div>
                        <button class="btn btn-sm btn-outline-primary me-2 eye-btn" onclick="toggleSavedRevision({{ rev.id }}, this)">
                            <i class="fas fa-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteRevision({{ rev.id }})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <div id="saved-result-area" class="result-area mt-4" style="display:none;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h4 text-muted">Fiche : <span id="saved-result-topic" class="text-dark"></span></h3>
                <div>
                    <button class="btn btn-sm btn-gold me-2" id="saved-play-btn">
                        <i class="fas fa-volume-up me-2"></i>Écouter
                    </button>
                    <button class="btn btn-sm btn-outline-danger me-2 d-none" id="saved-stop-btn">
                        <i class="fas fa-stop me-2"></i>Stop
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="collapseSavedRevision()">
                        <i class="fas fa-chevron-up me-1"></i>Réduire
                    </button>
                </div>
            </div>
            <hr>
            <div id="saved-markdown-output" class="markdown-content"></div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        let currentOpenId = null;

        function toggleSavedRevision(id, btn) {
            const section = document.getElementById('saved-section');
            const resultArea = document.getElementById('saved-result-area');

            // Même fiche déjà ouverte → collapse
            if (currentOpenId === id) {
                collapseSavedRevision();
                return;
            }

            // Nouvelle fiche
            const item = document.getElementById('saved-item-' + id);
            const topic = item.dataset.topic;
            const content = item.dataset.content;

            document.getElementById('saved-result-topic').textContent = topic;
            document.getElementById('saved-markdown-output').innerHTML = marked.parse(content);

            // Stocker le contenu pour la lecture audio
            resultArea.dataset.plainText = content.replace(/[#*_`~>\-]/g, '').trim();

            // Marquer le bouton actif
            document.querySelectorAll('.eye-btn').forEach(b => {
                b.classList.remove('btn-primary');
                b.classList.add('btn-outline-primary');
            });
            btn.classList.replace('btn-outline-primary', 'btn-primary');

            section.style.display = 'none';
            resultArea.style.display = 'block';
            resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' });
            currentOpenId = id;
        }

        function collapseSavedRevision() {
            speechSynthesis.cancel();
            document.getElementById('saved-result-area').style.display = 'none';
            document.getElementById('saved-section').style.display = 'block';
            document.getElementById('saved-stop-btn').classList.add('d-none');
            document.querySelectorAll('.eye-btn').forEach(b => {
                b.classList.remove('btn-primary');
                b.classList.add('btn-outline-primary');
            });
            currentOpenId = null;
        }

        function deleteRevision(id) {
            if (!confirm('Supprimer cette fiche ?')) return;
            fetch(`/ai/revision/saved/${id}/delete`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        if (currentOpenId === id) collapseSavedRevision();
                        document.getElementById('saved-item-' + id)?.remove();
                    }
                });
        }

        const savedPlayBtn = document.getElementById('saved-play-btn');
        const savedStopBtn = document.getElementById('saved-stop-btn');
        if (savedPlayBtn) {
            savedPlayBtn.addEventListener('click', function() {
                if (speechSynthesis.speaking) return;
                const text = document.getElementById('saved-result-area').dataset.plainText || '';
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'fr-FR';
                utterance.rate = 0.95;
                utterance.onend = () => savedStopBtn.classList.add('d-none');
                utterance.onerror = () => savedStopBtn.classList.add('d-none');
                savedStopBtn.classList.remove('d-none');
                speechSynthesis.speak(utterance);
            });
            savedStopBtn.addEventListener('click', function() {
                speechSynthesis.cancel();
                this.classList.add('d-none');
            });
        }
    </script>
    {% if result %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const rawContent = document.getElementById('markdown-output').innerHTML;
            // Decode HTML entities just in case Twig escaped them too much, though usually raw needed
            // Actually, let's just use the raw value if possible. 
            // Better: use a hidden textarea to hold the raw value
            const textArea = document.createElement('textarea');
            textArea.innerHTML = `{{ result|escape('js') }}`;
            const markdownText = textArea.value;
            
            document.getElementById('markdown-output').innerHTML = marked.parse(markdownText);
        });
        document.getElementById('play-audio-btn').addEventListener('click', function() {
            const stopBtn = document.getElementById('stop-audio-btn');

            if (speechSynthesis.speaking) return;

            const textarea = document.createElement('textarea');
            textarea.innerHTML = `{{ result|escape('js') }}`;
            const plainText = textarea.value.replace(/[#*_`~>\-]/g, '').trim();

            const utterance = new SpeechSynthesisUtterance(plainText);
            utterance.lang = 'fr-FR';
            utterance.rate = 0.95;

            utterance.onend = () => stopBtn.classList.add('d-none');
            utterance.onerror = () => stopBtn.classList.add('d-none');

            stopBtn.classList.remove('d-none');
            speechSynthesis.speak(utterance);
        });

        document.getElementById('stop-audio-btn').addEventListener('click', function() {
            speechSynthesis.cancel();
            this.classList.add('d-none');
        });

        document.getElementById('save-revision-btn').addEventListener('click', async function() {
            const btn = this;
            const textarea = document.createElement('textarea');
            textarea.innerHTML = `{{ result|escape('js') }}`;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sauvegarde...';

            try {
                const res = await fetch('{{ path("app_ai_revision_save") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ topic: `{{ topic|escape('js') }}`, content: textarea.value })
                });

                if (!res.ok) throw new Error();
                btn.innerHTML = '<i class="fas fa-check me-2"></i>Sauvegardé !';
                btn.classList.replace('btn-outline-success', 'btn-success');
                btn.disabled = true;
            } catch {
                btn.innerHTML = '<i class="fas fa-bookmark me-2"></i>Sauvegarder';
                btn.disabled = false;
                alert('Erreur lors de la sauvegarde.');
            }
        });
    </script>
    {% endif %}
{% endblock %}
