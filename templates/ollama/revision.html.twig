{% extends 'base.html.twig' %}

{% block title %}Révision Intelligente - EduTest{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .revision-page {
            background-color: #f8f9fa;
            padding: 3rem 0;
            min-height: 100vh;
        }
        .search-area {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin-bottom: 2rem;
        }
        .btn-gold {
            background-color: #FFD700;
            border-color: #FFC107;
            color: #212529;
        }
        .btn-gold:hover, .btn-gold:focus {
            background-color: #FFC107;
            border-color: #FFD700;
            color: #212529;
        }
        .result-area {
            background: white;
            border-radius: 15px;
            padding: 3rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            opacity: 0;
            animation: fadeIn 0.5s ease forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .loading-spinner {
            display: none;
        }
        .markdown-content h1 { color: #5a67d8; font-size: 2rem; margin-top: 1.5rem; }
        .markdown-content h2 { color: #4c51bf; font-size: 1.5rem; margin-top: 1.2rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; }
        .markdown-content ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
        .markdown-content li { margin-bottom: 0.5rem; }
        .markdown-content strong { color: #2d3748; }
    </style>
    {# Use marked.js for markdown rendering #}
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
{% endblock %}

{% block body %}
<div class="revision-page">
    <div class="container">
        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('student_exams') }}" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i> Retour</a>
            <h1 class="h2 fw-bold text-primary mb-0">Assistant de Révision</h1>
        </div>

        <!-- Formulaire -->
        <div class="search-area">
            <form method="post" onsubmit="document.getElementById('spinner').style.display = 'block';">
                <div class="mb-3">
                    <label for="topic" class="form-label h5">Sur quel sujet souhaitez-vous réviser ?</label>
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" id="topic" name="topic" placeholder="Ex: La Révolution Française, Algèbre Linéaire, Le cycle de l'eau..." required value="{{ topic }}">
                        <button class="btn btn-primary px-4" type="submit">
                            <i class="fas fa-magic me-2"></i>Générer
                        </button>
                    </div>
                    <div class="form-text mt-2">Notre IA analysera le sujet et créera une fiche complète.</div>
                </div>
            </form>
            
            <!-- Loader -->
            <div id="spinner" class="text-center py-4 loading-spinner">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Chargement...</span>
                </div>
                <p class="mt-3 text-muted">L'IA rédige votre fiche de révision, veuillez patienter...</p>
            </div>
        </div>

        <!-- Résultat -->
        {% if result %}
        <div class="result-area">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h4 text-muted">Fiche de révision : <span class="text-dark">{{ topic }}</span></h3>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-2" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>Imprimer
                    </button>
                    <button class="btn btn-sm btn-gold" id="play-audio-btn">
                        <i class="fas fa-volume-up me-2"></i>Écouter
                    </button>
                </div>
            </div>
            <hr>
            <div id="markdown-output" class="markdown-content">
                <!-- Le contenu brut sera converti par JS -->
                {{ result }}
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if result %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const rawContent = document.getElementById('markdown-output').innerHTML;
            // Decode HTML entities just in case Twig escaped them too much, though usually raw needed
            // Actually, let's just use the raw value if possible. 
            // Better: use a hidden textarea to hold the raw value
            const textArea = document.createElement('textarea');
            textArea.innerHTML = `{{ result|escape('js') }}`;
            const markdownText = textArea.value;
            
            document.getElementById('markdown-output').innerHTML = marked.parse(markdownText);
            document.getElementById('play-audio-btn').addEventListener('click', function() {
                fetch('{{ path('groq_speech') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ text: `{{ result|escape('js') }}` })
                })
                .then(response => response.blob())
                .then(blob => {
                    const audioUrl = URL.createObjectURL(blob);
                    const audio = new Audio(audioUrl);
                    audio.play();
                });
            });
        });
    </script>
    {% endif %}
{% endblock %}
