{% extends 'base.html.twig' %}

{% block title %}Assistant IA - EduTest{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .ai-dashboard {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 80vh;
            padding: 4rem 0;
        }
        .ai-card {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            cursor: pointer;
            height: 100%;
        }
        .ai-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .icon-wrapper {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2.5rem;
            color: white;
        }
        .icon-revision {
            background: linear-gradient(45deg, #667eea, #764ba2);
        }
        .icon-quiz {
            background: linear-gradient(45deg, #ff9a9e, #fad0c4);
        }
        .card-title {
            font-weight: 700;
            color: #2d3748;
        }
        .btn-custom {
            border-radius: 50px;
            padding: 10px 30px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
        }
        .btn-revision {
            background: linear-gradient(45deg, #667eea, #764ba2);
            border: none;
            color: white;
        }
        .btn-quiz {
            background: linear-gradient(45deg, #ff6b6b, #ff8e8e);
            border: none;
            color: white;
        }
        .btn-revision:hover, .btn-quiz:hover {
            transform: scale(1.05);
            color: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
    </style>
{% endblock %}

{% block body %}
<div class="ai-dashboard">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold mb-3" style="color: #2d3748;">Assistant Intelligent EduTest</h1>
            <p class="lead text-muted">Boostez vos révisions et testez vos connaissances grâce à notre IA performante.</p>
        </div>

        <div class="row justify-content-center g-4">
            <!-- Card Révision -->
            <div class="col-md-5 col-lg-4">
                <div class="card ai-card p-4 text-center h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-wrapper icon-revision mb-4">
                            <i class="fas fa-book-open"></i>
                        </div>
                        <h3 class="card-title h4 mb-3">Révision Intelligente</h3>
                        <p class="card-text text-muted mb-4">Générez des fiches de révision claires et structurées sur n'importe quel sujet en quelques secondes.</p>
                        <div class="mt-auto">
                            <a href="{{ path('app_ai_revision') }}" class="btn btn-custom btn-revision w-100">Commencer</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card Quiz -->
            <div class="col-md-5 col-lg-4">
                <div class="card ai-card p-4 text-center h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-wrapper icon-quiz mb-4">
                            <i class="fas fa-puzzle-piece"></i>
                        </div>
                        <h3 class="card-title h4 mb-3">Générateur de Quiz</h3>
                        <p class="card-text text-muted mb-4">Créez des quiz sur mesure pour tester vos connaissances et vous entraîner efficacement.</p>
                        <div class="mt-auto">
                            <a href="{{ path('app_ai_quiz') }}" class="btn btn-custom btn-quiz w-100">Créer un Quiz</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
